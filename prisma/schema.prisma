// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/client"
}

datasource db {
  provider = "postgresql"
}

enum EventStatus {
  PLANNED
  IN_PROGRESS
  DONE
  CANCELED
}

enum EventType {
  SOIL_PLOWING
  SOIL_HARROWING
  SOIL_SUBSOILING
  LIMING
  GYPSUM_APPLICATION
  PLANTING
  FERTILIZATION
  PESTICIDE_APPLICATION
  IRRIGATION
  HARVEST
  MONITORING
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
}

enum ProductCategory {
  DEFENSIVO_AGRICOLA
  FERTILIZANTE
  SEMENTE
  ADJUVANTE
  BIOLOGICO
  OUTRO
}

enum ProductClassification {
  HERBICIDA
  INSETICIDA
  FUNGICIDA
  NEMATICIDA
  ACARICIDA
  BACTERICIDA
  REGULADOR_CRESCIMENTO
  FERTILIZANTE_SOLO
  FERTILIZANTE_FOLIAR
  BIOESTIMULANTE
  INSETICIDA_BIOLOGICO
  FUNGICIDA_BIOLOGICO
  NEMATICIDA_BIOLOGICO
}

enum ExecutionMethod {
  DISTRIBUTING
  INCORPORATION
}

enum ApplicationMedium {
  DRONE
  AIRCRAFT
  TERRESTRIAL
}

enum ProductState {
  LIQUID
  SOLID
}

enum SeedQuantityUnit {
  SEED_M
  KG_HA
}

model Farm {
  id                   String  @id @default(cuid())
  name                 String
  location             String?
  is_active            Boolean @default(true)
  farm_map_document_id String?

  farm_map_document Document? @relation("FarmMapDocument", fields: [farm_map_document_id], references: [id], onDelete: SetNull)
  fields            Field[]
  users             User[]

  @@index([farm_map_document_id])
}

model Field {
  id                        String  @id @default(cuid())
  farm_id                   String
  code                      String
  name                      String
  area_ha                   Decimal @db.Decimal(10, 2)
  geo_boundary              Json?
  is_active                 Boolean @default(true)
  soil_analysis_document_id String?

  farm                   Farm         @relation(fields: [farm_id], references: [id])
  soil_analysis_document Document?    @relation("FieldSoilAnalysisDocument", fields: [soil_analysis_document_id], references: [id], onDelete: SetNull)
  field_events           FieldEvent[]

  @@unique([farm_id, code])
  @@index([farm_id])
  @@index([soil_analysis_document_id])
}

model User {
  id            String  @id @default(cuid())
  farm_id       String
  name          String
  email         String? @unique
  password_hash String
  role          String?
  is_active     Boolean @default(true)

  responsible_events FieldEvent[] @relation("ResponsibleUser")
  audit_logs         AuditLog[]
  farms              Farm         @relation(fields: [farm_id], references: [id])

  @@index([farm_id])
}

model Document {
  id               String   @id @default(cuid())
  file_name        String
  mime_type        String
  storage_path     String
  storage_provider String   @default("LOCAL")
  storage_key      String?
  public_url       String?
  secure_url       String?
  resource_type    String?
  file_size_bytes  Int?
  uploaded_at      DateTime @default(now())

  field_events         FieldEvent[]
  soil_analysis_fields Field[]      @relation("FieldSoilAnalysisDocument")
  farm_maps            Farm[]       @relation("FarmMapDocument")

  @@index([storage_key])
  @@index([storage_provider])
}

model FieldEvent {
  id                  String      @id @default(cuid())
  field_id            String
  event_type          EventType
  status              EventStatus
  start_at            DateTime
  end_at              DateTime
  responsible_user_id String
  notes               String?
  source_document_id  String?

  execution_method   ExecutionMethod?
  crop               String?
  variety            String?
  seed_quantity      Decimal?          @db.Decimal(12, 3)
  seed_quantity_unit SeedQuantityUnit?
  rainfall_mm        Decimal?          @db.Decimal(10, 2)

  field            Field     @relation(fields: [field_id], references: [id])
  responsible_user User      @relation("ResponsibleUser", fields: [responsible_user_id], references: [id])
  source_document  Document? @relation(fields: [source_document_id], references: [id])

  application       Application?
  application_items ApplicationItem[]

  @@index([field_id])
  @@index([responsible_user_id])
  @@index([source_document_id])
}

model Application {
  event_id              String   @id
  application_name      String
  work_rate_value       Decimal  @db.Decimal(10, 2)
  work_rate_unit        String
  spray_volume_total_l  Decimal? @db.Decimal(10, 2)
  spray_volume_l_per_ha Decimal? @db.Decimal(10, 2)
  tank_count_planned    Int?
  tank_count_actual     Int?
  preferred_period      String
  wind_min_kmh          Int
  wind_max_kmh          Int

  execution_method   ExecutionMethod?
  application_medium ApplicationMedium @default(TERRESTRIAL)
  product_state      ProductState?

  temp_min_c   Int?
  temp_max_c   Int?
  humidity_min Int?

  field_event FieldEvent @relation(fields: [event_id], references: [id])
}

model Product {
  id           String          @id @default(cuid())
  name         String
  category     ProductCategory
  default_unit String
  manufacturer String?
  notes        String?

  application_items ApplicationItem[]
}

model ApplicationItem {
  id                     String                 @id @default(cuid())
  event_id               String
  product_id             String
  product_classification ProductClassification?
  dose_per_ha            Decimal                @db.Decimal(10, 4)
  dose_unit              String
  total_planned          Decimal                @db.Decimal(12, 3)
  total_unit             String
  total_actual           Decimal?               @db.Decimal(12, 3)
  total_actual_unit      String?
  spray_solution_l       Decimal?               @db.Decimal(10, 2)
  packaging_count        Int?
  packaging_type         String?

  field_event FieldEvent @relation(fields: [event_id], references: [id])
  product     Product    @relation(fields: [product_id], references: [id])

  @@index([event_id])
  @@index([product_id])
}

model AuditLog {
  id                 String      @id @default(cuid())
  entity_type        String
  entity_id          String
  action             AuditAction
  changed_by_user_id String
  changed_at         DateTime    @default(now())
  before_json        Json?
  after_json         Json?

  changed_by_user User @relation(fields: [changed_by_user_id], references: [id])

  @@index([entity_type, entity_id])
  @@index([changed_by_user_id])
}
